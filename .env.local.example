# ------------------------------------------------------------------
# SparkLaunch environment variables
# Copy this file to `.env.local` and fill in your Supabase project keys.
# The app runs with local seed data even if these are left blank.
# ------------------------------------------------------------------

# Public Supabase project URL, e.g. https://xxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Public anon key (safe to expose in the browser)
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Simple password gate for the /admin dashboard (demo only)
NEXT_PUBLIC_ADMIN_PASSWORD=sparklaunch
